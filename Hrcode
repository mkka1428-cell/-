function buildPanel(id){
  const d=DATA[id];
  const files=d.files.map(f=>`<div class="file-card"><div class="file-icon ${f.ic}">${f.em}</div><div><div class="file-name">${f.name}</div><div class="file-desc">${f.desc}</div><a href="${f.file}" download class="file-dl">⬇ تنزيل</a></div></div>`).join('');
  const steps=d.steps.map((s,i)=>`<li><span class="sn">${i+1}</span><span>${s}</span></li>`).join('');
  return `<div class="panel"><div class="panel-header ${d.hdr}"><span class="panel-header-icon">${d.icon}</span><div><div class="panel-header-title">${d.title}</div><div class="panel-header-weeks">${d.weeks}</div></div></div><div class="panel-body"><div class="intro-box">${d.intro}</div><div class="files-label">📂 الملفات المطلوبة في هذه المرحلة</div><div class="files-grid">${files}</div><div class="steps-box"><div class="steps-title">🔧 خطوات الاستخدام</div><ul class="steps-list">${steps}</ul></div></div></div>`;
}

let active=null;
function togglePhase(id,btn){
  const r1=document.getElementById('row1'),r2=document.getElementById('row2');
  document.querySelectorAll('.phase-btn').forEach(b=>b.classList.remove('active'));
  if(active===id){r1.style.display='none';r2.style.display='none';r1.innerHTML='';r2.innerHTML='';active=null;return;}
  active=id;btn.classList.add('active');
  const html=buildPanel(id);
  if(id<=3){r2.style.display='none';r2.innerHTML='';r1.innerHTML=html;r1.style.display='block';setTimeout(()=>r1.scrollIntoView({behavior:'smooth',block:'nearest'}),50);}
  else{r1.style.display='none';r1.innerHTML='';r2.innerHTML=html;r2.style.display='block';setTimeout(()=>r2.scrollIntoView({behavior:'smooth',block:'nearest'}),50);}
}
function toggleManual(){
  const p=document.getElementById('manualPanel');
  p.style.display=p.style.display==='none'?'block':'none';
}
